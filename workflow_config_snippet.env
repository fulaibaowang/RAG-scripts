# Snippet RRF route overrides (--snippet-rrf).
# Source after your main config, then run: ./run_retrieval_rerank_pipeline.sh -c <main.env> --snippet-rrf
# Or: source workflow_config_full.env && source workflow_config_snippet.env && ./run_retrieval_rerank_pipeline.sh --snippet-rrf
#
# When --snippet-rrf is set, the pipeline uses upstream RRF pool=200, runs snippet extraction + CE rerank,
# fuses rerank_hybrid (0.8) + snippet_rerank (0.2), and builds contexts from top-2 CE windows per doc.

# Stage A (hybrid filter for windows)
SNIPPET_DENSE_MODEL=BAAI/bge-base-en-v1.5
SNIPPET_DENSE_DEVICE=cpu

# Input: top N docs from rerank_hybrid per query
SNIPPET_N_DOCS=100

# Windows: size 3, stride 1, keep top W per doc after Stage A
SNIPPET_WINDOW_SIZE=3
SNIPPET_WINDOW_STRIDE=1
SNIPPET_TOP_W=8

# Stage B (CE rerank)
SNIPPET_CE_MODEL=BAAI/bge-reranker-v2-m3
SNIPPET_CE_DEVICE=auto
SNIPPET_CE_BATCH=64
SNIPPET_CE_MAX_LENGTH=512

# Final RRF: rerank_hybrid (docs) 0.8 + snippet_rerank 0.2
SNIPPET_RRF_W_DOCS=0.8
SNIPPET_RRF_W_SNIPPET=0.2
SNIPPET_FINAL_POOL=50
SNIPPET_RRF_K=60

# Evidence: top K windows per doc for context (non-overlapping sentences, title once)
SNIPPET_CONTEXT_TOP_WINDOWS=2
