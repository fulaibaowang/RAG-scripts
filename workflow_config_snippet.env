# Snippet workflow config: standalone example for the snippet-RRF route.
# Usage: source workflow_config_snippet.env && ./run_retrieval_rerank_pipeline.sh --snippet-rrf
#
# When --snippet-rrf is set, the pipeline uses upstream RRF pool=200, runs snippet extraction + CE rerank,
# fuses rerank_hybrid (0.8) + snippet_rerank (0.2), and builds contexts from top-2 CE windows per doc.

# ---------- Shared (paths + retrieval depth) ----------
# Required: set your local paths
WORKFLOW_OUTPUT_DIR=/path/to/output/snippet_run
TRAIN_JSON=/path/to/training.json
TEST_BATCH_JSONS="/path/to/test1.json  /path/to/test2.json"

# Retrieval depth and recall points (same semantics as in baseline/full configs)
TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# Index paths (set to your indexes)
BM25_INDEX_PATH=/path/to/terrier_index
DENSE_INDEX_DIR=/path/to/dense_index

# Reranker corpus (optional; required if you want evidence/generation)
# DOCS_JSONL=/path/to/pubmed.jsonl
RERANK_CANDIDATE_LIMIT=2000

# ---------- Snippet RRF parameters ----------

# Stage A (hybrid filter for windows)
SNIPPET_DENSE_MODEL=BAAI/bge-base-en-v1.5
SNIPPET_DENSE_DEVICE=cpu

# Input: top N docs from rerank_hybrid per query
SNIPPET_N_DOCS=100

# Windows: size 3, stride 1, keep top W per doc after Stage A
SNIPPET_WINDOW_SIZE=3
SNIPPET_WINDOW_STRIDE=1
SNIPPET_TOP_W=8

# Stage B (CE rerank; optional multi-GPU)
SNIPPET_CE_MODEL=BAAI/bge-reranker-v2-m3
SNIPPET_CE_DEVICE=auto
SNIPPET_CE_BATCH=64
SNIPPET_CE_MAX_LENGTH=512
# SNIPPET_CE_USE_MULTI_GPU=   # default: same as RERANK_USE_MULTI_GPU if unset
# SNIPPET_CE_NUM_GPUS=        # default: same as RERANK_NUM_GPUS if unset

# Final RRF: rerank_hybrid (docs) 0.8 + snippet_rerank 0.2
SNIPPET_RRF_W_DOCS=0.8
SNIPPET_RRF_W_SNIPPET=0.2
SNIPPET_FINAL_POOL=${SNIPPET_N_DOCS}
SNIPPET_RRF_K=60

# Evidence: top K windows per doc for context (non-overlapping sentences, title once)
SNIPPET_CONTEXT_TOP_WINDOWS=2
