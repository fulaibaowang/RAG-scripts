# Full workflow config: baseline + snippet routes.
# Usage: source conf/workflow_config_full.env && ./run_retrieval_rerank_pipeline.sh [--run-both-routes]
# All tunable parameters with defaults and ranges: docs/PARAMETERS.md

# ---------- Shared (paths + retrieval depth) ----------
# SHARED_SCRIPTS_DIR=/absolute/path/to/shared_scripts   # override when vendored elsewhere

WORKFLOW_OUTPUT_DIR=/path/to/output/full_run
INPUT_JSONL=/path/to/training.jsonl
INPUT_BATCH_JSONLS="/path/to/test1.jsonl  /path/to/test2.jsonl"
DOCS_JSONL=/path/to/literature.jsonl

TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# ---------- Index paths ----------
BM25_INDEX_PATH=/path/to/terrier_index_full
DENSE_INDEX_DIR=/path/to/dense_index_full

# ---------- BM25 + RM3 ----------
# BM25_TOP_K=5000              # override retrieval depth for BM25 (default: TOP_K)
# BM25_JAVA_MEM=8g
# BM25_DISABLE_RM3=1           # set to 1 to run plain BM25 without RM3

# ---------- Dense ----------
# DENSE_MODEL_NAME=            # override SentenceTransformer model from index meta
# DENSE_EF_CAP=2000            # cap on ef_search to bound runtime (default: no cap)

# ---------- Retrieval Fusion (BM25 + Dense RRF) ----------
# RETRIEVAL_FUSION_MODE=sweep  # sweep (default) or default (single k_rrf + weights)
# RETRIEVAL_FUSION_K_RRF=150   # RRF k in default mode
# RETRIEVAL_FUSION_W_BM25=1.0
# RETRIEVAL_FUSION_W_DENSE=1.0

# ---------- Reranker ----------
RERANK_CANDIDATE_LIMIT=2000    # max candidates per query; pipeline clamps to min(this, RETRIEVAL_FUSION_CAP) then [100–2000]
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_MODEL_MAX_LENGTH=512
# RERANK_USE_MULTI_GPU=1
# RERANK_RERANKER_TYPE=llm     # cross_encoder (default) or llm (e.g. bge-reranker-v2-gemma)

# ---------- RRF fusion (Retrieval + Rerank) ----------
RRF_POOL_TOP_RERANK=50         # top-K from reranker for fusion pool
RRF_POOL_TOP_RETRIEVAL=50      # top-K from retrieval fusion for fusion pool
# RRF_K=60
# RRF_W_RERANK=0.8
# RRF_W_RETRIEVAL=0.2          # default: 1 - RRF_W_RERANK

# ---------- Post-fusion score cutoff (t*) ----------
# RERANK_TSTAR_ENABLE=1        # set to 1 to enable
# RERANK_TSTAR=                # threshold on reranker score (required when ENABLE=1)
# RERANK_TSTAR_FLOOR=5         # min docs kept per query

# ---------- Snippet RRF route ----------
# RUN_SNIPPET_RRF=1            # enable snippet route (or pass --snippet-rrf / --run-both-routes)
SNIPPET_DENSE_MODEL=abhinand/MedEmbed-small-v0.1
SNIPPET_N_DOCS=100
# SNIPPET_CE_MODEL=            # default: RERANK_MODEL
# SNIPPET_CE_DEVICE=cuda       # Stage B CE device (default: cuda)

# ---------- Listwise reranking (separate container) ----------
# RUN_LISTWISE=1
# LISTWISE_CONTAINER_IMG=
# LISTWISE_MODEL=castorini/rank_zephyr_7b_v1_full
# LISTWISE_OUTPUT_DIR=         # default: $WORKFLOW_OUTPUT_DIR/listwise_rerank

# ---------- Evidence ----------
POST_RERANK_DOC_POOL=30        # max docs per query written into post_rerank_*.jsonl
EVIDENCE_TOP_K=10              # max docs per question used when building evidence contexts

# ---------- Generation ----------
# GENERATION_BACKEND=ollama    # ollama (default) or openai_compat
# GENERATION_BACKEND=openai_compat
# GEN_API_BASE=https://openrouter.ai/api/v1
# GENERATION_MODEL=llama3.3:latest
GENERATION_MAX_CONTEXTS=8      # pipeline default: 8 for baseline, 10 for snippet
# GENERATION_SYSTEM_PATH=/path/to/custom/system.txt
# GENERATION_SCHEMAS_DIR=/path/to/custom/schemas
