# Full workflow config: document + snippet routes.
# Usage: source conf/workflow_config_full.env && ./run_retrieval_rerank_pipeline.sh [--run-both-routes]
# All tunable parameters with defaults and ranges: docs/PARAMETERS.md

# ---------- Shared (paths + retrieval depth) ----------
# SHARED_SCRIPTS_DIR=/absolute/path/to/shared_scripts   # override when vendored elsewhere

WORKFLOW_OUTPUT_DIR=/path/to/output/full_run
INPUT_JSONL=/path/to/training.jsonl
INPUT_BATCH_JSONLS="/path/to/test1.jsonl  /path/to/test2.jsonl"
DOCS_JSONL=/path/to/literature.jsonl

# Retrieval depth (rows per query in stage-1 run TSVs).
# Chunk-aware corpora: this is **chunk-level** because retrieval/rerank/fusion
# all carry chunk identity. Aggregation to PMID happens later (eval rail
# inside evaluate_run; pipeline rail inside build_retrieval_jsonl). Bump
# higher for chunked corpora than for abstracts-only, since each paper may
# contribute multiple chunks to the candidate pool.
TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# ---------- Index paths ----------
BM25_INDEX_PATH=/path/to/terrier_index_full
DENSE_INDEX_DIR=/path/to/dense_index_full

# ---------- BM25 + RM3 ----------
# BM25_TOP_K=5000              # override retrieval depth for BM25 (default: TOP_K)
# BM25_JAVA_MEM=8g
# BM25_DISABLE_RM3=1           # set to 1 to run plain BM25 without RM3

# ---------- Dense ----------
# DENSE_MODEL_NAME=            # override SentenceTransformer model from index meta
# DENSE_EF_CAP=2000            # cap on ef_search to bound runtime (default: no cap)

# ---------- Retrieval Fusion (BM25 + Dense RRF) ----------
# RETRIEVAL_FUSION_MODE=default  # default (single fixed k_rrf + weights, writes downstream run);
                                 # sweep = diagnostic only (metrics/plots, no run TSV for reranker)
# RETRIEVAL_FUSION_K_RRF=60      # RRF k in default mode
# RETRIEVAL_FUSION_W_BM25=1.0
# RETRIEVAL_FUSION_W_DENSE=1.0

# ---------- Reranker ----------
# Chunk-aware: candidates are chunk-level for chunked corpora.
RERANK_CANDIDATE_LIMIT=2000    # max candidates per query; pipeline clamps to min(this, RETRIEVAL_FUSION_CAP) then [100–2000]
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_MODEL_MAX_LENGTH=512
# RERANK_USE_MULTI_GPU=1
# RERANK_RERANKER_TYPE=llm     # cross_encoder (default) or llm (e.g. bge-reranker-v2-gemma)

# ---------- RRF fusion (Retrieval + Rerank) ----------
# Chunk-aware: pool is **chunk-level** for chunked corpora — bump
# proportionally to MAX_CHUNKS_PER_PMID so each paper still has room to
# express multiple chunks in the fusion.
RRF_POOL_TOP_RERANK=50         # top-K from reranker for fusion pool
RRF_POOL_TOP_RETRIEVAL=50      # top-K from retrieval fusion for fusion pool
# RRF_K=60
# RRF_W_RERANK=0.8
# RRF_W_RETRIEVAL=0.2          # default: 1 - RRF_W_RERANK

# ---------- Post-fusion score cutoff (t*) ----------
# RERANK_TSTAR_ENABLE=1        # set to 1 to enable
# RERANK_TSTAR=                # threshold on reranker score (required when ENABLE=1)
# RERANK_TSTAR_FLOOR=5         # min docs kept per query

# ---------- Snippet RRF route ----------
# Chunk-aware: SNIPPET_N_DOCS counts chunk-level docs for chunked corpora.
# RUN_SNIPPET_RRF=1            # enable snippet route (or pass --snippet-rrf / --run-both-routes)
SNIPPET_DENSE_MODEL=abhinand/MedEmbed-small-v0.1
SNIPPET_N_DOCS=100
# SNIPPET_CE_MODEL=            # default: RERANK_MODEL
# SNIPPET_CE_DEVICE=cuda       # Stage B CE device (default: cuda)

# ---------- Listwise reranking (separate container) ----------
# RUN_LISTWISE=1
# LISTWISE_CONTAINER_IMG=
# LISTWISE_MODEL=castorini/rank_zephyr_7b_v1_full
# LISTWISE_OUTPUT_DIR=         # default: $WORKFLOW_OUTPUT_DIR/listwise_rerank

# ---------- Evidence ----------
# Chunk-aware: build_retrieval_jsonl enforces top-K **distinct PMIDs**
# (chunks of the same paper count as one). Each PMID may contribute up to
# MAX_CHUNKS_PER_PMID chunks to the doc_ids list — so doc_ids size <=
# POST_RERANK_DOC_POOL * MAX_CHUNKS_PER_PMID. Both build_doc_contexts and
# build_snippet_contexts then emit exactly one context per distinct PMID,
# with chunks aggregated (concat for the doc route; pooled top-N windows
# for the snippet route).
POST_RERANK_DOC_POOL=30        # max **distinct PMIDs** per query in post_rerank_*.jsonl
# MAX_CHUNKS_PER_PMID=2        # max chunks of the same paper kept in doc_ids
                               # (default 2). Set to 1 for "one canonical chunk
                               # per paper". Read by the pipeline orchestrator
                               # and forwarded to build_retrieval_jsonl.
EVIDENCE_TOP_K=10              # max chunk-level doc_ids per question consumed when
                               # building evidence; contexts emitted one per distinct
                               # PMID, so context count <= EVIDENCE_TOP_K (often less).

# ---------- Generation ----------
# GENERATION_BACKEND=ollama    # ollama (default) or openai_compat
# GENERATION_BACKEND=openai_compat
# GEN_API_BASE=https://openrouter.ai/api/v1
# GENERATION_MODEL=llama3.3:latest
GENERATION_MAX_CONTEXTS=8      # pipeline default: 8 for document, 10 for snippet.
                               # One context per PMID — value is in PMIDs, not chunks.
# GENERATION_SYSTEM_PATH=/path/to/custom/system.txt
# GENERATION_SCHEMAS_DIR=/path/to/custom/schemas
# CITATION_GRANULARITY=answer       # answer (default) | sentence (reserved, not yet implemented)
#                                   #   answer: one answer-level evidence_ids list per question;
#                                   #           output JSONL byte-identical to the plain pipeline.
#                                   #   sentence: per-sentence citation route (planned); fails fast.

# ---------- Generation: context distillation (optional) ----------
# Rewrite the generation contexts before the answer prompt: an LLM extracts atomic claims
# from many more contexts than fit a raw prompt, then the claims are packed into the prompt
# budget. Default off ("direct") = byte-identical to the plain pipeline. Ollama backend only.
# GENERATION_MODE=direct            # direct (default) | claims | facets
#                                   #   claims: extract_claims -> distil_claims (claim slots)
#                                   #   facets: extract_claims -> summarize_facets -> select_contexts
# GENERATION_EXTRACT_MODEL=llama3.3:latest   # extractor LLM; falls back to GENERATION_MODEL
# GENERATION_EXTRACT_URL=            # ollama generate endpoint; falls back to OLLAMA_URL
# GENERATION_EXTRACT_TOP_N=30        # contexts per query to extract claims from (also the
#                                    # cache cut used by distil/summarize)
# GENERATION_EXTRACT_MAX_CHARS=4000  # passage truncation for the extract prompt
# GENERATION_EXTRACT_TIMEOUT=120
# GENERATION_EXTRACT_RETRIES=3
# GENERATION_EXTRACT_RETRY_SLEEP=10
# GENERATION_EXTRACT_THINK=          # force ollama think flag; unset = key absent (do not
#                                    # set false for gemma: it degrades extraction)
# GENERATION_DISTIL_SLOTS=           # claims mode: fixed slot count (overrides word budget)
# GENERATION_DISTIL_BUDGET_WORDS=944 # claims mode: word budget when slots unset
# GENERATION_FACET_DIST_THR=0.4      # facets mode: agglomerative clustering distance threshold
# GENERATION_FACET_MIN_CLUSTER=2     # facets mode: summarize facets with >= this many claims
# GENERATION_FACET_EMB_MODEL=all-MiniLM-L6-v2  # bi-encoder for clustering + selection
# GENERATION_SUMMARY_MODEL=          # summarizer LLM; falls back to GENERATION_EXTRACT_MODEL
# GENERATION_SUMMARY_URL=            # falls back to GENERATION_EXTRACT_URL then OLLAMA_URL
# GENERATION_SUMMARY_NUM_CTX=8192    # summarizer context window (independent of GENERATION_NUM_CTX)
# GENERATION_SUMMARY_TIMEOUT=600
# GENERATION_SUMMARY_CONCURRENCY=3
# GENERATION_SUMMARY_THINK=          # force ollama think flag; unset = auto (off for gemma)
# GENERATION_SELECT_N=16             # facets mode: slots kept by slot-text hybrid RRF
# GENERATION_SELECT_RRF_K=60         # RRF k for the semantic+lexical fusion
# GENERATION_MAX_CONTEXTS_DISTILLED=100        # generation caps when mode != direct: high by
# GENERATION_MAX_CHARS_PER_CONTEXT_DISTILLED=1800  # default so distilled slots never truncate
# GENERATION_NUM_CTX=16384           # generator context window: distilled prompts are dense;
#                                    # raise this (never cut slots) if answers truncate
