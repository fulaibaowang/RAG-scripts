# Document-route workflow config: sensible defaults for the standard pipeline
# (document-level contexts, one record per PMID). Pairs with workflow_config_snippet.env.
# Usage: source conf/workflow_config_document.env && ./run_retrieval_rerank_pipeline.sh
# All tunable parameters with defaults and ranges: docs/PARAMETERS.md

# ---------- Shared (paths + retrieval depth) ----------
WORKFLOW_OUTPUT_DIR=/path/to/output/document_run
INPUT_JSONL=/path/to/training.jsonl
INPUT_BATCH_JSONLS="/path/to/test1.jsonl  /path/to/test2.jsonl"
DOCS_JSONL=/path/to/literature.jsonl

# Retrieval depth (rows per query in stage-1 run TSVs).
# Chunk-aware corpora: this is **chunk-level**; aggregation to PMID happens
# inside evaluate_run (eval rail) and inside build_retrieval_jsonl
# (pipeline rail). Bump higher for chunked corpora than for abstracts-only.
TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# ---------- Index paths ----------
BM25_INDEX_PATH=/path/to/terrier_index
DENSE_INDEX_DIR=/path/to/dense_index

# ---------- Reranker ----------
# Chunk-aware: candidates are chunk-level for chunked corpora.
RERANK_CANDIDATE_LIMIT=2000
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ---------- RRF fusion (Retrieval + Rerank) ----------
# Chunk-aware: pool is chunk-level for chunked corpora.
RRF_POOL_TOP_RERANK=50
RRF_POOL_TOP_RETRIEVAL=50
# If unset, RRF_W_RETRIEVAL will be derived as 1 - RRF_W_RERANK

# ---------- Evidence (chunk-aware) ----------
# build_retrieval_jsonl enforces top-K **distinct PMIDs** (chunks of the
# same paper count as one). MAX_CHUNKS_PER_PMID controls how many chunks
# of each paper land in doc_ids (CLI default 2).
# Both build_doc_contexts and build_snippet_contexts then emit exactly one
# context per distinct PMID.
# POST_RERANK_DOC_POOL=30      # max distinct PMIDs in post_rerank_*.jsonl
# MAX_CHUNKS_PER_PMID=2        # max chunks of the same paper kept in doc_ids
# EVIDENCE_TOP_K=10            # max chunk-level doc_ids consumed per question
